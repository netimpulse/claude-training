<section class="usp-bar color-scheme color-{{ section.settings.color_scheme.id }}" data-section-id="{{ section.id }}">
  <div class="usp-bar__inner">
    {%- for block in section.blocks -%}
      <div class="usp-bar__item" {{ block.shopify_attributes }}>
        {%- if block.settings.icon != blank -%}
          <div class="usp-bar__icon">
            {%- assign usp_alt = block.settings.heading | default: '' | escape -%}
            {{ block.settings.icon | image_url: width: 96 | image_tag:
               loading: 'lazy', sizes: '48px', widths: '48,96,144', alt: usp_alt }}
          </div>
        {%- endif -%}
        <div class="usp-bar__text">
          <strong>{{ block.settings.heading | escape }}</strong>
          {%- if block.settings.subtext != blank -%}<span>{{ block.settings.subtext | escape }}</span>{%- endif -%}
        </div>
      </div>
    {%- endfor -%}
  </div>
</section>
{% style %}
  {%- assign scheme = section.settings.color_scheme -%}
  {%- if scheme -%}
  .color-{{ scheme.id }} {
    --color-background: {{ scheme.settings.background.red }}, {{ scheme.settings.background.green }}, {{ scheme.settings.background.blue }};
    --color-text: {{ scheme.settings.text.red }}, {{ scheme.settings.text.green }}, {{ scheme.settings.text.blue }};
    --color-button: {{ scheme.settings.button.red }}, {{ scheme.settings.button.green }}, {{ scheme.settings.button.blue }};
    --color-button-label: {{ scheme.settings.button_label.red }}, {{ scheme.settings.button_label.green }}, {{ scheme.settings.button_label.blue }};
    --color-secondary-button-label: {{ scheme.settings.secondary_button_label.red }}, {{ scheme.settings.secondary_button_label.green }}, {{ scheme.settings.secondary_button_label.blue }};
    --color-shadow: {{ scheme.settings.shadow.red }}, {{ scheme.settings.shadow.green }}, {{ scheme.settings.shadow.blue }};
    color: rgb(var(--color-text));
    background-color: rgb(var(--color-background));
    {%- if scheme.settings.background_gradient != blank -%}
    background: {{ scheme.settings.background_gradient }};
    {%- endif -%}
  }
  {%- endif -%}

  #shopify-section-{{ section.id }} { --usp-bg: {{ section.settings.bg_color }}; --usp-fg: {{ section.settings.text_color }}; }
{% endstyle %}
{{ 'section-usp-bar.css' | asset_url | stylesheet_tag }}
{% schema %}
{
  "name": "t:sections.usp_bar.name_usp_bar",
  "tag": "section",
  "class": "section-usp-bar",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.usp_bar.label_farbschema",
      "default": "scheme-1"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "t:sections.usp_bar.label_hintergrund",
      "default": "#f6f5f2"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "t:sections.usp_bar.label_text",
      "default": "#111111"
    }
  ],
  "blocks": [
    {
      "type": "usp",
      "name": "t:sections.usp_bar_blocks.name_usp",
      "limit": 6,
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "t:sections.usp_bar.label_icon_optional"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "t:sections.usp_bar.label_ueberschrift",
          "default": "t:sections.usp_bar.default_kostenloser_versand"
        },
        {
          "type": "text",
          "id": "subtext",
          "label": "t:sections.usp_bar.label_untertext",
          "default": "t:sections.usp_bar.default_ab_80_bestellwert"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.usp_bar.preset_usp_bar",
      "blocks": [
        {
          "type": "usp",
          "settings": {
            "heading": "Kostenloser Versand",
            "subtext": "Ab 80 €"
          }
        },
        {
          "type": "usp",
          "settings": {
            "heading": "30 Tage Rückgabe",
            "subtext": "Unkompliziert"
          }
        },
        {
          "type": "usp",
          "settings": {
            "heading": "Sichere Bezahlung",
            "subtext": "SSL-verschlüsselt"
          }
        },
        {
          "type": "usp",
          "settings": {
            "heading": "Nachhaltig",
            "subtext": "Zertifizierte Materialien"
          }
        }
      ],
      "settings": {
        "color_scheme": "scheme-1"
      }
    }
  ],
  "disabled_on": {
    "groups": [
      "header",
      "footer"
    ]
  }
}
{% endschema %}
