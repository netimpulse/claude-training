{%- comment -%}
  Split Collection Banner — two side-by-side collection cards (e.g. Herren | Damen).
  Fully responsive, turns stacked on mobile.
{%- endcomment -%}

{{ 'section-split-collection.css' | asset_url | stylesheet_tag }}

{%- assign scheme = section.settings.color_scheme -%}
<section
  class="split-collection color-scheme color-{{ scheme.id }}"
  data-section-id="{{ section.id }}"
>
  {% style %}
    {%- if scheme -%}
    .color-{{ scheme.id }} {
      --color-background: {{ scheme.settings.background.red }}, {{ scheme.settings.background.green }}, {{ scheme.settings.background.blue }};
      --color-text: {{ scheme.settings.text.red }}, {{ scheme.settings.text.green }}, {{ scheme.settings.text.blue }};
      --color-button: {{ scheme.settings.button.red }}, {{ scheme.settings.button.green }}, {{ scheme.settings.button.blue }};
      --color-button-label: {{ scheme.settings.button_label.red }}, {{ scheme.settings.button_label.green }}, {{ scheme.settings.button_label.blue }};
      color: rgb(var(--color-text));
      background-color: rgb(var(--color-background));
      {%- if scheme.settings.background_gradient != blank -%}
      background: {{ scheme.settings.background_gradient }};
      {%- endif -%}
    }
    {%- endif -%}
    #shopify-section-{{ section.id }} {
      --section-padding-top: {{ section.settings.padding_top }}px;
      --section-padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  {% endstyle %}

  {%- if section.settings.heading != blank -%}
    <h2 class="split-collection__heading">{{ section.settings.heading | escape }}</h2>
  {%- endif -%}

  <div class="split-collection__grid">
    {%- for block in section.blocks -%}
      {%- liquid
        assign col = block.settings.collection
        assign img = block.settings.image | default: col.image
        assign link = block.settings.link
        if link == blank and col != blank
          assign link = col.url
        endif
        assign title = block.settings.heading
        if title == blank and col != blank
          assign title = col.title
        endif
      -%}
      <div class="split-collection__card" {{ block.shopify_attributes }}>
        <a href="{{ link | default: '#' }}" class="split-collection__link" aria-label="{{ title | escape }}">
          <div class="split-collection__media">
            {%- if img != blank -%}
              {%- assign card_alt = title | default: shop.name | escape -%}
              {{ img | image_url: width: 1200 | image_tag:
                loading: 'lazy',
                sizes: '(min-width: 768px) 50vw, 100vw',
                widths: '400,600,800,1000,1200',
                alt: card_alt,
                class: 'split-collection__image'
              }}
            {%- else -%}
              <div class="split-collection__placeholder">{{ 'collection-1' | placeholder_svg_tag }}</div>
            {%- endif -%}
            <div class="split-collection__overlay" style="opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};"></div>
          </div>
          <div class="split-collection__content">
            {%- if block.settings.eyebrow != blank -%}
              <span class="split-collection__eyebrow">{{ block.settings.eyebrow | escape }}</span>
            {%- endif -%}
            {%- if title != blank -%}
              <h3 class="split-collection__title">{{ title | escape }}</h3>
            {%- endif -%}
            {%- if block.settings.button_text != blank -%}
              <span class="split-collection__btn">{{ block.settings.button_text | escape }}</span>
            {%- endif -%}
          </div>
        </a>
      </div>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "t:sections.split_collection.name",
  "tag": "section",
  "class": "section-split-collection",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:labels.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.heading"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "%",
      "label": "t:sections.split_collection.overlay",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:labels.padding_top",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:labels.padding_bottom",
      "default": 0
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "t:sections.split_collection.block_name",
      "limit": 4,
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "t:labels.collection"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:labels.image",
          "info": "t:sections.split_collection.image_info"
        },
        {
          "type": "text",
          "id": "eyebrow",
          "label": "t:labels.subheading"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "t:labels.heading"
        },
        {
          "type": "text",
          "id": "button_text",
          "label": "t:labels.button_text",
          "default": "t:sections.split_collection.btn_default"
        },
        {
          "type": "url",
          "id": "link",
          "label": "t:labels.button_link",
          "info": "t:sections.split_collection.link_info"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.split_collection.preset_name",
      "blocks": [
        {
          "type": "card",
          "settings": {
            "heading": "t:sections.split_collection.preset_heading_1",
            "button_text": "t:sections.split_collection.btn_default"
          }
        },
        {
          "type": "card",
          "settings": {
            "heading": "t:sections.split_collection.preset_heading_2",
            "button_text": "t:sections.split_collection.btn_default"
          }
        }
      ]
    }
  ],
  "disabled_on": {
    "groups": ["header", "footer"]
  }
}
{% endschema %}
