    },
    {
      "type": "url",
      "id": "social_facebook",
      "label": "t:sections.footer.label_facebook_url"
    },
    {
      "type": "url",
      "id": "social_youtube",
      "label": "t:sections.footer.label_youtube_url"
    },
    {
      "type": "url",
      "id": "social_pinterest",
      "label": "t:sections.footer.label_pinterest_url"
    },
    {
      "type": "header",
      "content": "t:sections.footer.content_rechtliches_shopify_policies"
