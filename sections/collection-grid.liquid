<section class="coll-grid color-scheme color-{{ section.settings.color_scheme.id }}" data-section-id="{{ section.id }}">
  {%- if section.settings.heading != blank -%}
    <div class="coll-grid__head">
      <h2 class="coll-grid__title">{{ section.settings.heading | escape }}</h2>
      {%- if section.settings.subheading != blank -%}
        <p class="coll-grid__sub">{{ section.settings.subheading | escape }}</p>
      {%- endif -%}
    </div>
  {%- endif -%}

  <div class="coll-grid__items" style="--cols: {{ section.settings.columns }};">
    {%- for block in section.blocks -%}
      {%- liquid
        assign col = block.settings.collection
        assign link = block.settings.link
        if link == blank and col != blank
          assign link = col.url
        endif
        assign img = block.settings.image
        if img == blank and col != blank
          assign img = col.featured_image | default: col.products.first.featured_image
        endif
      -%}
      <a href="{{ link | default: '#' }}" class="coll-grid__card" {{ block.shopify_attributes }}>
        <div class="coll-grid__media">
          {%- if img != blank -%}
            {%- assign coll_alt = block.settings.heading | default: col.title | escape -%}
            {{ img | image_url: width: 900 | image_tag:
               loading: 'lazy',
               sizes: '(min-width: 990px) 33vw, 50vw',
               widths: '300,450,600,750,900',
               alt: coll_alt,
               class: 'coll-grid__image' }}
          {%- else -%}
            {{ 'lifestyle-2' | placeholder_svg_tag: 'coll-grid__placeholder' }}
          {%- endif -%}
        </div>
        <div class="coll-grid__caption">
          <h3>{{ block.settings.heading | default: col.title | escape }}</h3>
          {%- if block.settings.subtext != blank -%}<span>{{ block.settings.subtext | escape }}</span>{%- endif -%}
        </div>
      </a>
    {%- endfor -%}
  </div>
</section>
{% style %}
  {%- assign scheme = section.settings.color_scheme -%}
  {%- if scheme -%}
  .color-{{ scheme.id }} {
    --color-background: {{ scheme.settings.background.red }}, {{ scheme.settings.background.green }}, {{ scheme.settings.background.blue }};
    --color-text: {{ scheme.settings.text.red }}, {{ scheme.settings.text.green }}, {{ scheme.settings.text.blue }};
    --color-button: {{ scheme.settings.button.red }}, {{ scheme.settings.button.green }}, {{ scheme.settings.button.blue }};
    --color-button-label: {{ scheme.settings.button_label.red }}, {{ scheme.settings.button_label.green }}, {{ scheme.settings.button_label.blue }};
    --color-secondary-button-label: {{ scheme.settings.secondary_button_label.red }}, {{ scheme.settings.secondary_button_label.green }}, {{ scheme.settings.secondary_button_label.blue }};
    --color-shadow: {{ scheme.settings.shadow.red }}, {{ scheme.settings.shadow.green }}, {{ scheme.settings.shadow.blue }};
    color: rgb(var(--color-text));
    background-color: rgb(var(--color-background));
    {%- if scheme.settings.background_gradient != blank -%}
    background: {{ scheme.settings.background_gradient }};
    {%- endif -%}
  }
  {%- endif -%}

  #shopify-section-{{ section.id }} {
    --cg-bg: {{ section.settings.bg_color }};
    --cg-fg: {{ section.settings.text_color }};
    --cg-padding-top: {{ section.settings.padding_top }}px;
    --cg-padding-bottom: {{ section.settings.padding_bottom }}px;
  }
{% endstyle %}
{{ 'section-collection-grid.css' | asset_url | stylesheet_tag }}
{% schema %}
{
  "name": "t:sections.collection_grid.name_kollektionen_grid",
  "tag": "section",
  "class": "section-collection-grid",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.collection_grid.label_farbschema",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.collection_grid.label_ueberschrift",
      "default": "t:sections.collection_grid.default_shop_by_category"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "t:sections.collection_grid.label_unterueberschrift"
    },
    {
      "type": "range",
      "id": "columns",
      "min": 2,
      "max": 6,
      "step": 1,
      "label": "t:sections.collection_grid.label_spalten_desktop",
      "default": 3
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "t:sections.collection_grid.label_hintergrund",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "t:sections.collection_grid.label_text",
      "default": "#111111"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "t:sections.collection_grid.label_abstand_oben",
      "default": 56
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "t:sections.collection_grid.label_abstand_unten",
      "default": 56
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "t:sections.collection_grid_blocks.name_kategorie",
      "limit": 12,
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "t:sections.collection_grid.label_kollektion"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:sections.collection_grid.label_bild_ueberschreibt_kollektions_bild"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "t:sections.collection_grid.label_ueberschrift_ueberschreibt_kollektions_t"
        },
        {
          "type": "text",
          "id": "subtext",
          "label": "t:sections.collection_grid.label_untertext"
        },
        {
          "type": "url",
          "id": "link",
          "label": "t:sections.collection_grid.label_link_ueberschreibt_kollektions_url"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.collection_grid.preset_kollektionen_grid",
      "blocks": [
        {
          "type": "category",
          "settings": {
            "heading": "Damen"
          }
        },
        {
          "type": "category",
          "settings": {
            "heading": "Herren"
          }
        },
        {
          "type": "category",
          "settings": {
            "heading": "Jacken"
          }
        },
        {
          "type": "category",
          "settings": {
            "heading": "Accessoires"
          }
        }
      ],
      "settings": {
        "color_scheme": "scheme-1"
      }
    }
  ],
  "disabled_on": {
    "groups": [
      "header",
      "footer"
    ]
  }
}
{% endschema %}
