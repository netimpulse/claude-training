{%- comment -%}
  Cart section — clean, modern layout.
  • Product image, title, variant, price
  • Quantity stepper with +/- buttons
  • Line total + remove link
  • Cart summary with subtotal + checkout button
  • Empty-state message
{%- endcomment -%}

{{ 'section-cart.css' | asset_url | stylesheet_tag }}

{%- assign scheme = section.settings.color_scheme -%}

<section
  class="cart-section color-scheme color-{{ scheme.id }}"
  data-section-id="{{ section.id }}"
>
  {% style %}
    {%- if scheme -%}
    .color-{{ scheme.id }} {
      --color-background: {{ scheme.settings.background.red }}, {{ scheme.settings.background.green }}, {{ scheme.settings.background.blue }};
      --color-text: {{ scheme.settings.text.red }}, {{ scheme.settings.text.green }}, {{ scheme.settings.text.blue }};
      color: rgb(var(--color-text));
      background-color: rgb(var(--color-background));
    }
    {%- endif -%}
    #shopify-section-{{ section.id }} {
      --section-padding-top: {{ section.settings.padding_top }}px;
      --section-padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  {% endstyle %}

  <div class="cart-section__inner page-width">
    <h1 class="cart-section__title">{{ 'cart.title' | t }}</h1>

    {%- if cart.item_count > 0 -%}
      <form action="{{ routes.cart_url }}" method="post" id="cart-form" class="cart-section__form">
        <div class="cart-section__layout">
          {%- comment -%} ====== ITEMS ====== {%- endcomment -%}
          <div class="cart-section__items">
            {%- comment -%} Header row (desktop) {%- endcomment -%}
            <div class="cart-section__header">
              <span class="cart-section__header-product">{{ 'cart.headings.product' | t }}</span>
              <span class="cart-section__header-qty">{{ 'cart.headings.quantity' | t }}</span>
              <span class="cart-section__header-total">{{ 'cart.headings.total' | t }}</span>
            </div>

            {%- for item in cart.items -%}
              <div class="cart-section__item" data-line="{{ forloop.index }}">
                {%- comment -%} Image {%- endcomment -%}
                <a href="{{ item.url }}" class="cart-section__item-image" aria-label="{{ item.product.title | escape }}">
                  {%- if item.image != blank -%}
                    {%- assign img_alt = item.image.alt | default: item.product.title | escape -%}
                    {{ item.image | image_url: width: 300 | image_tag:
                      loading: 'lazy',
                      sizes: '120px',
                      widths: '120,240',
                      alt: img_alt,
                      class: 'cart-section__image'
                    }}
                  {%- else -%}
                    {{ 'product-1' | placeholder_svg_tag: 'cart-section__placeholder' }}
                  {%- endif -%}
                </a>

                {%- comment -%} Product info {%- endcomment -%}
                <div class="cart-section__item-info">
                  <a href="{{ item.url }}" class="cart-section__item-title">
                    {{ item.product.title | escape }}
                  </a>
                  {%- if item.product.has_only_default_variant == false -%}
                    <p class="cart-section__item-variant">{{ item.variant.title | escape }}</p>
                  {%- endif -%}
                  <p class="cart-section__item-price">{{ item.original_price | money }}</p>
                  {%- if item.original_price != item.final_price -%}
                    <p class="cart-section__item-discount">{{ item.final_price | money }}</p>
                  {%- endif -%}
                </div>

                {%- comment -%} Quantity stepper {%- endcomment -%}
                <div class="cart-section__item-qty">
                  <label class="visually-hidden" for="CartQty-{{ forloop.index }}">
                    {{ 'cart.quantity' | t }}
                  </label>
                  <div class="cart-section__qty-stepper">
                    <button
                      type="button"
                      class="cart-section__qty-btn"
                      aria-label="{{ 'cart.decrease' | t: title: item.product.title }}"
                      data-qty-change="-1"
                      data-line="{{ forloop.index }}"
                    >&minus;</button>
                    <input
                      type="number"
                      id="CartQty-{{ forloop.index }}"
                      class="cart-section__qty-input"
                      name="updates[]"
                      value="{{ item.quantity }}"
                      min="0"
                      aria-label="{{ 'cart.quantity' | t }}"
                      data-line="{{ forloop.index }}"
                    >
                    <button
                      type="button"
                      class="cart-section__qty-btn"
                      aria-label="{{ 'cart.increase' | t: title: item.product.title }}"
                      data-qty-change="1"
                      data-line="{{ forloop.index }}"
                    >+</button>
                  </div>
                  <a href="{{ item.url_to_remove }}" class="cart-section__remove">
                    {{ 'cart.remove' | t }}
                  </a>
                </div>

                {%- comment -%} Line total {%- endcomment -%}
                <div class="cart-section__item-total">
                  {{ item.final_line_price | money }}
                </div>
              </div>
            {%- endfor -%}
          </div>

          {%- comment -%} ====== SUMMARY ====== {%- endcomment -%}
          <div class="cart-section__summary">
            <div class="cart-section__summary-inner">
              <div class="cart-section__subtotal-row">
                <span>{{ 'cart.subtotal' | t }}</span>
                <span class="cart-section__subtotal-price">{{ cart.total_price | money }}</span>
              </div>

              {%- if cart.cart_level_discount_applications.size > 0 -%}
                {%- for discount in cart.cart_level_discount_applications -%}
                  <div class="cart-section__discount-row">
                    <span>{{ discount.title }}</span>
                    <span>-{{ discount.total_allocated_amount | money }}</span>
                  </div>
                {%- endfor -%}
              {%- endif -%}

              <p class="cart-section__tax-note">
                {{ 'cart.taxes_and_shipping' | t }}
              </p>

              {%- if section.settings.show_note -%}
                <div class="cart-section__note">
                  <label for="CartNote-{{ section.id }}" class="cart-section__note-label">
                    {{ 'cart.note' | t }}
                  </label>
                  <textarea
                    id="CartNote-{{ section.id }}"
                    class="cart-section__note-input"
                    name="note"
                    rows="3"
                    placeholder="{{ 'cart.note_placeholder' | t }}"
                  >{{ cart.note }}</textarea>
                </div>
              {%- endif -%}

              <button type="submit" name="checkout" class="cart-section__checkout btn btn--primary">
                {{ 'cart.checkout' | t }}
              </button>

              <button type="submit" name="update" class="cart-section__update btn btn--secondary">
                {{ 'cart.update' | t }}
              </button>
            </div>
          </div>
        </div>
      </form>

    {%- else -%}
      {%- comment -%} Empty cart {%- endcomment -%}
      <div class="cart-section__empty">
        <p class="cart-section__empty-text">{{ 'cart.empty' | t }}</p>
        <a href="{{ routes.all_products_collection_url }}" class="btn btn--primary cart-section__continue">
          {{ 'cart.continue_shopping' | t }}
        </a>
      </div>
    {%- endif -%}
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    document.querySelectorAll('[data-qty-change]').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var change = parseInt(this.dataset.qtyChange);
        var line = this.dataset.line;
        var input = document.getElementById('CartQty-' + line);
        if (input) {
          var newVal = Math.max(0, parseInt(input.value) + change);
          input.value = newVal;
        }
      });
    });
  });
</script>

{% schema %}
{
  "name": "t:general.cart",
  "tag": "section",
  "class": "section-cart",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:labels.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "checkbox",
      "id": "show_note",
      "label": "t:cart.show_note",
      "default": true
    },
    {
      "type": "header",
      "content": "t:labels.padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:labels.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:labels.padding_bottom",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "t:general.cart"
    }
  ]
}
{% endschema %}
