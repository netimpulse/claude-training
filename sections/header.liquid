<header
  class="site-header {% if section.settings.sticky %}site-header--sticky{% endif %} site-header--{{ section.settings.layout }}"
  role="banner"
  data-section-id="{{ section.id }}"
>
  <a class="site-header__skip visually-hidden" href="#MainContent">
    {{ 'general.skip_to_content' | t }}
  </a>

  <div class="site-header__inner">
    {%- comment -%} LEFT: Burger {%- endcomment -%}
    <div class="site-header__left">
      <button type="button" class="site-header__icon-btn"
              aria-label="{{ 'general.navigation.menu_open' | t }}"
              aria-expanded="false" aria-controls="mega-menu-drawer" data-drawer-toggle="mega-menu">
        {%- render 'icon', name: 'menu' -%}
        {%- if section.settings.burger_label != blank -%}
          <span class="site-header__burger-label">{{ section.settings.burger_label | escape }}</span>
        {%- endif -%}
      </button>
    </div>

    {%- comment -%} CENTER: logo + nav (always 1 grid child) {%- endcomment -%}
    <div class="site-header__center">
      <div class="site-header__logo">
        {%- render 'site-logo', settings: section.settings -%}
      </div>
      {%- if section.settings.show_main_menu -%}
        <nav class="site-header__nav" aria-label="{{ 'general.navigation.categories' | t }}">
          {%- render 'site-main-menu', menu: section.settings.main_menu -%}
        </nav>
      {%- endif -%}
    </div>

    {%- comment -%} RIGHT: Icons {%- endcomment -%}
    <div class="site-header__right">
      {%- if section.settings.show_search -%}
        <button type="button" class="site-header__icon-btn"
                aria-label="{{ 'general.accessibility.search_icon' | t }}"
                aria-expanded="false" aria-controls="search-drawer" data-drawer-toggle="search">
          {%- render 'icon', name: 'search' -%}
        </button>
      {%- endif -%}

      {%- if shop.customer_accounts_enabled and section.settings.show_account -%}
        <a href="{{ routes.account_url }}" class="site-header__icon-btn" aria-label="{{ 'general.accessibility.account' | t }}">
          {%- render 'icon', name: 'account' -%}
        </a>
      {%- endif -%}

      <a href="{{ routes.cart_url }}" class="site-header__icon-btn site-header__cart" aria-label="{{ 'general.accessibility.cart_icon' | t }}">
        {%- render 'icon', name: 'cart' -%}
        <span class="site-header__cart-count" data-cart-count aria-live="polite" aria-atomic="true">
          <span class="visually-hidden">{{ 'general.accessibility.items_in_cart' | t }}&nbsp;</span>
          {{ cart.item_count }}
        </span>
      </a>
    </div>
  </div>

  {%- comment -%} SEARCH DRAWER {%- endcomment -%}
  {%- if section.settings.show_search -%}
    <div id="search-drawer" class="site-drawer site-drawer--search" data-drawer="search" aria-hidden="true">
      <div class="site-drawer__backdrop" data-drawer-close></div>
      <div class="site-drawer__panel site-drawer__panel--top" role="dialog" aria-label="{{ 'general.accessibility.search_icon' | t }}" aria-modal="true">
        <form action="{{ routes.search_url }}" method="get" role="search" class="site-drawer__search-form">
          <input type="hidden" name="type" value="product">
          <label for="SearchInput-{{ section.id }}" class="visually-hidden">{{ 'general.search.placeholder' | t }}</label>
          <input type="search" id="SearchInput-{{ section.id }}" name="q" placeholder="{{ 'general.search.placeholder' | t }}" class="site-drawer__search-input" autocomplete="off" enterkeyhint="search">
          <button type="submit" class="site-drawer__search-submit" aria-label="{{ 'general.search.submit' | t }}">
            {%- render 'icon', name: 'search' -%}
          </button>
          <button type="button" class="site-drawer__close" data-drawer-close aria-label="{{ 'general.search.close' | t }}">
            {%- render 'icon', name: 'close' -%}
          </button>
        </form>
      </div>
    </div>
  {%- endif -%}

  {%- comment -%} MEGA MENU DRAWER {%- endcomment -%}
  {%- assign drawer_title_text = section.settings.drawer_title | default: 'general.navigation.categories' | t -%}
  <div id="mega-menu-drawer" class="site-drawer site-drawer--mega" data-drawer="mega-menu" aria-hidden="true">
    <div class="site-drawer__backdrop" data-drawer-close></div>
    <nav class="site-drawer__panel site-drawer__panel--left" role="dialog" aria-label="{{ drawer_title_text }}" aria-modal="true">
      <div class="site-drawer__header">
        <span class="site-drawer__title">{{ drawer_title_text | escape }}</span>
        <button type="button" class="site-drawer__close" data-drawer-close aria-label="{{ 'general.accessibility.close' | t }}">
          {%- render 'icon', name: 'close' -%}
        </button>
      </div>
      <div class="site-drawer__menu">
        {%- if section.settings.drawer_menu != blank -%}
          <ul class="site-drawer__list" role="list">
            {%- for link in section.settings.drawer_menu.links -%}
              <li class="site-drawer__item">
                {%- if link.links.size > 0 -%}
                  <details class="site-drawer__details">
                    <summary class="site-drawer__summary">
                      <span>{{ link.title | escape }}</span>
                      {%- render 'icon', name: 'chevron' -%}
                    </summary>
                    <ul class="site-drawer__sublist" role="list">
                      {%- assign all_link_text = 'general.navigation.all_link' | t: title: link.title -%}
                      <li><a class="site-drawer__sublink site-drawer__sublink--all" href="{{ link.url }}">{{ all_link_text }}</a></li>
                      {%- for sub in link.links -%}
                        <li>
                          <a class="site-drawer__sublink" href="{{ sub.url }}">{{ sub.title | escape }}</a>
                          {%- if sub.links.size > 0 -%}
                            <ul class="site-drawer__sub2list" role="list">
                              {%- for sub2 in sub.links -%}
                                <li><a class="site-drawer__sub2link" href="{{ sub2.url }}">{{ sub2.title | escape }}</a></li>
                              {%- endfor -%}
                            </ul>
                          {%- endif -%}
                        </li>
                      {%- endfor -%}
                    </ul>
                  </details>
                {%- else -%}
                  <a class="site-drawer__link" href="{{ link.url }}">{{ link.title | escape }}</a>
                {%- endif -%}
              </li>
            {%- endfor -%}
          </ul>
        {%- else -%}
          <p class="site-drawer__empty">{{ 'general.navigation.empty_drawer' | t }}</p>
        {%- endif -%}

        {%- if section.blocks.size > 0 -%}
          <div class="site-drawer__extra">
            {%- for block in section.blocks -%}
              <div class="site-drawer__extra-item" {{ block.shopify_attributes }}>
                {%- case block.type -%}
                  {%- when 'promo_card' -%}
                    {%- if block.settings.image != blank -%}
                      {%- assign promo_alt = block.settings.heading | default: 'Promo' | escape -%}
                      <a href="{{ block.settings.link | default: '#' }}" class="site-drawer__promo">
                        {{ block.settings.image | image_url: width: 600 | image_tag: loading: 'lazy', sizes: '320px', widths: '320,480,640', alt: promo_alt, class: 'site-drawer__promo-image' }}
                        <div class="site-drawer__promo-content">
                          <strong>{{ block.settings.heading | escape }}</strong>
                          {%- if block.settings.text != blank -%}<p>{{ block.settings.text | escape }}</p>{%- endif -%}
                        </div>
                      </a>
                    {%- endif -%}
                  {%- when 'text_link' -%}
                    {%- if block.settings.link != blank -%}
                      <a href="{{ block.settings.link }}" class="site-drawer__text-link">{{ block.settings.text | escape }}</a>
                    {%- endif -%}
                {%- endcase -%}
              </div>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>
    </nav>
  </div>
</header>

{% style %}
  #shopify-section-{{ section.id }} {
    --header-bg: {{ section.settings.bg_color }};
    --header-fg: {{ section.settings.text_color }};
    --header-height: {{ section.settings.height }}px;
    --header-accent: {{ section.settings.accent_color }};
  }
{% endstyle %}

{{ 'section-header.css' | asset_url | stylesheet_tag }}
<script src="{{ 'site-header.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "t:sections.header.name",
  "tag": "section",
  "class": "section-site-header",
  "settings": [
    { "type": "header", "content": "t:sections.header.layout" },
    {
      "type": "select", "id": "layout", "label": "t:sections.header.logo_position", "default": "logo_center",
      "options": [
        { "value": "logo_left", "label": "t:sections.header.logo_position_left" },
        { "value": "logo_center", "label": "t:sections.header.logo_position_center" }
      ]
    },
    { "type": "checkbox", "id": "sticky", "label": "t:sections.header.sticky", "default": true },
    { "type": "range", "id": "height", "min": 56, "max": 120, "step": 4, "unit": "px", "label": "t:sections.header.height", "default": 80 },
    { "type": "header", "content": "t:sections.header.logo" },
    { "type": "image_picker", "id": "logo", "label": "t:sections.header.logo_image" },
    { "type": "range", "id": "logo_width", "min": 60, "max": 300, "step": 10, "unit": "px", "label": "t:sections.header.logo_width", "default": 140 },
    { "type": "header", "content": "t:sections.header.main_menu" },
    { "type": "checkbox", "id": "show_main_menu", "label": "t:sections.header.show_main_menu", "default": true },
    { "type": "link_list", "id": "main_menu", "label": "t:sections.header.menu", "default": "main-menu" },
    { "type": "header", "content": "t:sections.header.burger_drawer" },
    { "type": "text", "id": "burger_label", "label": "t:sections.header.burger_label" },
    { "type": "text", "id": "drawer_title", "label": "t:sections.header.drawer_title" },
    { "type": "link_list", "id": "drawer_menu", "label": "t:sections.header.drawer_menu" },
    { "type": "header", "content": "t:sections.header.icons" },
    { "type": "checkbox", "id": "show_search", "label": "t:sections.header.show_search", "default": true },
    { "type": "checkbox", "id": "show_account", "label": "t:sections.header.show_account", "default": true },
    { "type": "header", "content": "t:sections.header.colors" },
    { "type": "color", "id": "bg_color", "label": "t:sections.header.bg_color", "default": "#ffffff" },
    { "type": "color", "id": "text_color", "label": "t:sections.header.text_color", "default": "#111111" },
    { "type": "color", "id": "accent_color", "label": "t:sections.header.accent_color", "default": "#111111" }
  ],
  "blocks": [
    {
      "type": "promo_card", "name": "t:sections.header_blocks.promo_card", "limit": 3,
      "settings": [
        { "type": "image_picker", "id": "image", "label": "t:sections.header_blocks.promo_image" },
        { "type": "text", "id": "heading", "label": "t:sections.header_blocks.promo_heading", "default": "t:sections.header_blocks.promo_heading_default" },
        { "type": "text", "id": "text", "label": "t:sections.header_blocks.promo_text" },
        { "type": "url", "id": "link", "label": "t:sections.header_blocks.promo_link" }
      ]
    },
    {
      "type": "text_link", "name": "t:sections.header_blocks.text_link", "limit": 4,
      "settings": [
        { "type": "text", "id": "text", "label": "t:sections.header_blocks.text_link_text", "default": "t:sections.header_blocks.text_link_text_default" },
        { "type": "url", "id": "link", "label": "t:sections.header_blocks.text_link_link" }
      ]
    }
  ]
}
{% endschema %}
