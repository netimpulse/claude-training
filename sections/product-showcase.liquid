{%- liquid
  assign product = section.settings.product
  assign has_product = false
  if product != blank
    assign has_product = true
  endif
  if has_product
    assign current_variant = product.selected_or_first_available_variant
  endif
  assign form_id = 'product-form-' | append: section.id
-%}

<section class="product-showcase color-scheme color-{{ section.settings.color_scheme.id }}" data-section-id="{{ section.id }}">
  <div class="product-showcase__grid">
    {%- comment -%} ====== MEDIA SIDE ====== {%- endcomment -%}
    <div class="product-showcase__media">
      {%- comment -%} Tab switcher (Video / 3D / Images) {%- endcomment -%}
      {%- liquid
        assign has_video = false
        assign has_3d = false
        if section.settings.video != blank or section.settings.video_url != blank
          assign has_video = true
        endif
        assign first_model = nil
        if has_product
          for media in product.media
            if media.media_type == 'model'
              assign first_model = media
              break
            endif
          endfor
        endif
        if first_model != nil
          assign has_3d = true
        endif
      -%}

      <div class="product-showcase__tabs" role="tablist">
        {%- if has_video -%}
          <button type="button" class="product-showcase__tab is-active" role="tab" data-media-tab="video" aria-selected="true">Video</button>
        {%- endif -%}
        {%- if has_3d -%}
          <button type="button" class="product-showcase__tab {% unless has_video %}is-active{% endunless %}" role="tab" data-media-tab="model" aria-selected="{% if has_video %}false{% else %}true{% endif %}">3D-Ansicht</button>
        {%- endif -%}
        {%- if has_product -%}
          <button type="button" class="product-showcase__tab {% unless has_video or has_3d %}is-active{% endunless %}" role="tab" data-media-tab="gallery" aria-selected="{% if has_video or has_3d %}false{% else %}true{% endif %}">Bilder</button>
        {%- endif -%}
      </div>

      {%- comment -%} ===== VIDEO PANEL ===== {%- endcomment -%}
      {%- if has_video -%}
        <div class="product-showcase__panel is-active" data-media-panel="video">
          <product-video
            class="product-video"
            data-autoplay-once="{{ section.settings.autoplay_once }}"
            data-replay-on-hover="true"
          >
            {%- if section.settings.video != blank -%}
              {%- liquid
                assign poster_src = ''
                if section.settings.last_frame != blank
                  assign poster_src = section.settings.last_frame | image_url: width: 1200
                elsif section.settings.video.preview_image != blank
                  assign poster_src = section.settings.video.preview_image | image_url: width: 1200
                endif
              -%}
              <video
                class="product-video__el"
                playsinline
                muted
                preload="metadata"
                {% if poster_src != '' %}poster="{{ poster_src }}"{% endif %}
              >
                {%- for source in section.settings.video.sources -%}
                  <source src="{{ source.url }}" type="video/{{ source.format }}">
                {%- endfor -%}
              </video>
            {%- elsif section.settings.video_url != blank -%}
              <div class="product-video__embed">
                {%- if section.settings.video_url.type == 'youtube' -%}
                  <iframe
                    src="https://www.youtube.com/embed/{{ section.settings.video_url.id }}?autoplay=1&mute=1&controls=0&playsinline=1&rel=0&modestbranding=1"
                    title="Produkt-Video"
                    frameborder="0"
                    allow="autoplay; encrypted-media; picture-in-picture"
                    allowfullscreen
                  ></iframe>
                {%- else -%}
                  <iframe
                    src="https://player.vimeo.com/video/{{ section.settings.video_url.id }}?autoplay=1&muted=1&controls=0"
                    title="Produkt-Video"
                    frameborder="0"
                    allow="autoplay; fullscreen; picture-in-picture"
                    allowfullscreen
                  ></iframe>
                {%- endif -%}
              </div>
            {%- endif -%}

            {%- if section.settings.last_frame != blank -%}
              <img
                class="product-video__poster"
                {{ section.settings.last_frame | image_url: width: 1600 | image_tag:
                   loading: 'lazy',
                   sizes: '(min-width: 990px) 50vw, 100vw',
                   widths: '600,900,1200,1600',
                   alt: 'Produkt-Standbild' }}
              >
            {%- else -%}
              <canvas class="product-video__poster product-video__poster--canvas" aria-hidden="true"></canvas>
            {%- endif -%}

            <button type="button" class="product-video__replay" aria-label="Video erneut abspielen">
              {%- render 'icon', name: 'play' -%}
            </button>
          </product-video>
        </div>
      {%- endif -%}

      {%- comment -%} ===== 3D MODEL PANEL ===== {%- endcomment -%}
      {%- if has_3d -%}
        <div class="product-showcase__panel {% unless has_video %}is-active{% endunless %}" data-media-panel="model">
          <product-model class="product-model">
            {{
              first_model
              | model_viewer_tag:
                reveal: 'interaction',
                toggleable: true,
                image_size: '1600x',
                loading: 'lazy'
            }}
          </product-model>
        </div>
      {%- endif -%}

      {%- comment -%} ===== GALLERY PANEL (product images) ===== {%- endcomment -%}
      {%- if has_product -%}
        <div class="product-showcase__panel {% unless has_video or has_3d %}is-active{% endunless %}" data-media-panel="gallery">
          <div class="product-showcase__gallery">
            {%- for media in product.media limit: 6 -%}
              {%- if media.media_type == 'image' -%}
                {%- assign gallery_alt = media.alt | default: product.title | escape -%}
                {{
                  media
                  | image_url: width: 1200
                  | image_tag:
                    loading: 'lazy',
                    sizes: '(min-width: 990px) 45vw, 100vw',
                    widths: '450,600,900,1200',
                    alt: gallery_alt,
                    class: 'product-showcase__gallery-image'
                }}
              {%- endif -%}
            {%- endfor -%}
          </div>
        </div>
      {%- endif -%}
    </div>

    {%- comment -%} ====== INFO / FORM SIDE ====== {%- endcomment -%}
    <div class="product-showcase__info">
      {%- if section.settings.eyebrow != blank -%}
        <p class="product-showcase__eyebrow">{{ section.settings.eyebrow | escape }}</p>
      {%- endif -%}

      <h2 class="product-showcase__title">
        {%- if has_product -%}
          <a href="{{ product.url }}">{{ product.title | escape }}</a>
        {%- else -%}
          {{ section.settings.fallback_title | default: 'Produkt auswählen' | escape }}
        {%- endif -%}
      </h2>

      {%- if has_product and product.vendor != blank and section.settings.show_vendor -%}
        <p class="product-showcase__vendor">{{ product.vendor | escape }}</p>
      {%- endif -%}

      {%- if section.settings.description != blank -%}
        <div class="product-showcase__desc">{{ section.settings.description }}</div>
      {%- elsif has_product -%}
        <div class="product-showcase__desc">{{ product.description | truncatewords: 80 }}</div>
      {%- endif -%}

      {%- if has_product -%}
        <div class="product-showcase__price" data-price-wrap>
          {%- render 'product-price', product: product, variant: current_variant -%}
        </div>

        <product-form
          class="product-form"
          data-section="{{ section.id }}"
          data-product-url="{{ product.url }}"
          data-product-handle="{{ product.handle }}"
        >
          <script type="application/json" data-product-json>
            {{ product.variants | json }}
          </script>

          {%- form 'product', product, id: form_id, class: 'product-form__form', novalidate: 'novalidate' -%}
            <input type="hidden" name="id" value="{{ current_variant.id }}" data-variant-id-input>

            {%- unless product.has_only_default_variant -%}
              <div class="product-form__options">
                {%- for option in product.options_with_values -%}
                  {%- liquid
                    assign option_handle = option.name | handle
                    assign is_color = false
                    if option_handle contains 'color' or option_handle contains 'farbe'
                      assign is_color = true
                    endif
                  -%}
                  <fieldset class="product-form__fieldset" data-option-index="{{ forloop.index0 }}">
                    <legend class="product-form__legend">
                      <span class="product-form__option-name">{{ option.name | escape }}</span>
                      <span class="product-form__option-value" data-option-value="{{ forloop.index0 }}">{{ option.selected_value | escape }}</span>
                    </legend>
                    <div class="product-form__swatches product-form__swatches--{% if is_color %}color{% else %}size{% endif %}">
                      {%- for value in option.values -%}
                        <label class="product-form__swatch {% if option.selected_value == value %}is-selected{% endif %}">
                          <input
                            type="radio"
                            name="options[{{ option.name | escape }}]"
                            value="{{ value | escape }}"
                            data-option-input="{{ forloop.parentloop.index0 }}"
                            {% if option.selected_value == value %}checked{% endif %}
                          >
                          {%- if is_color -%}
                            <span class="product-form__swatch-color" style="background: {{ value | handle }};" aria-hidden="true"></span>
                          {%- endif -%}
                          <span class="product-form__swatch-label">{{ value | escape }}</span>
                        </label>
                      {%- endfor -%}
                    </div>
                  </fieldset>
                {%- endfor -%}
              </div>
            {%- endunless -%}

            <div class="product-form__quantity">
              <label for="Quantity-{{ section.id }}">Menge</label>
              <div class="product-form__quantity-input">
                <button type="button" aria-label="Weniger" data-qty-minus>−</button>
                <input id="Quantity-{{ section.id }}" type="number" name="quantity" value="1" min="1" inputmode="numeric">
                <button type="button" aria-label="Mehr" data-qty-plus>+</button>
              </div>
            </div>

            <button
              type="submit"
              class="product-form__submit"
              data-add-to-cart
              {% unless current_variant.available %}disabled{% endunless %}
            >
              <span data-atc-label>
                {% if current_variant.available %}In den Warenkorb{% else %}Ausverkauft{% endif %}
              </span>
            </button>

            {%- if section.settings.show_buy_now -%}
              <button type="button" class="product-form__buy-now" data-buy-now>Sofort kaufen</button>
            {%- endif -%}
          {%- endform -%}

          {%- if section.settings.show_meta -%}
            <ul class="product-showcase__meta" role="list">
              {%- if section.settings.meta_1 != blank -%}<li>{{ section.settings.meta_1 | escape }}</li>{%- endif -%}
              {%- if section.settings.meta_2 != blank -%}<li>{{ section.settings.meta_2 | escape }}</li>{%- endif -%}
              {%- if section.settings.meta_3 != blank -%}<li>{{ section.settings.meta_3 | escape }}</li>{%- endif -%}
            </ul>
          {%- endif -%}

          {%- comment -%} Extra info blocks (accordion) {%- endcomment -%}
          {%- if section.blocks.size > 0 -%}
            <div class="product-showcase__accordion">
              {%- for block in section.blocks -%}
                {%- case block.type -%}
                  {%- when 'accordion' -%}
                    <details class="product-showcase__accordion-item" {{ block.shopify_attributes }}>
                      <summary>
                        <span>{{ block.settings.heading | escape }}</span>
                        {%- render 'icon', name: 'chevron' -%}
                      </summary>
                      <div class="product-showcase__accordion-body">{{ block.settings.content }}</div>
                    </details>
                {%- endcase -%}
              {%- endfor -%}
            </div>
          {%- endif -%}
        </product-form>
      {%- else -%}
        <div class="product-showcase__empty">
          <p>Wähle im Theme-Editor ein Produkt aus, um Varianten (Größe, Farbe) und den Warenkorb-Button zu aktivieren.</p>
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

{% style %}
  {%- assign scheme = section.settings.color_scheme -%}
  {%- if scheme -%}
  .color-{{ scheme.id }} {
    --color-background: {{ scheme.settings.background.red }}, {{ scheme.settings.background.green }}, {{ scheme.settings.background.blue }};
    --color-text: {{ scheme.settings.text.red }}, {{ scheme.settings.text.green }}, {{ scheme.settings.text.blue }};
    --color-button: {{ scheme.settings.button.red }}, {{ scheme.settings.button.green }}, {{ scheme.settings.button.blue }};
    --color-button-label: {{ scheme.settings.button_label.red }}, {{ scheme.settings.button_label.green }}, {{ scheme.settings.button_label.blue }};
    --color-secondary-button-label: {{ scheme.settings.secondary_button_label.red }}, {{ scheme.settings.secondary_button_label.green }}, {{ scheme.settings.secondary_button_label.blue }};
    --color-shadow: {{ scheme.settings.shadow.red }}, {{ scheme.settings.shadow.green }}, {{ scheme.settings.shadow.blue }};
    color: rgb(var(--color-text));
    background-color: rgb(var(--color-background));
    {%- if scheme.settings.background_gradient != blank -%}
    background: {{ scheme.settings.background_gradient }};
    {%- endif -%}
  }
  {%- endif -%}

  #shopify-section-{{ section.id }} {
    --ps-bg: {{ section.settings.bg_color }};
    --ps-fg: {{ section.settings.text_color }};
    --ps-accent: {{ section.settings.accent_color }};
    --ps-padding-top: {{ section.settings.padding_top }}px;
    --ps-padding-bottom: {{ section.settings.padding_bottom }}px;
  }
{% endstyle %}

{%- if has_3d -%}
  <script src="https://cdn.shopify.com/shopifycloud/model-viewer/v4.0/model-viewer.js" type="module"></script>
{%- endif -%}

{{ 'section-product-showcase.css' | asset_url | stylesheet_tag }}
<script src="{{ 'product-showcase.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "t:sections.product_showcase.name_produkt_showcase",
  "tag": "section",
  "class": "section-product-showcase",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.product_showcase.label_farbschema",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:sections.product_showcase.content_produkt"
    },
    {
      "type": "product",
      "id": "product",
      "label": "t:sections.product_showcase.label_produkt",
      "info": "t:sections.product_showcase.info_varianten_groesse_farbe_und_warenkorb_bu"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "t:sections.product_showcase.label_eyebrow_kleiner_text_oben",
      "default": "t:sections.product_showcase.default_neu"
    },
    {
      "type": "text",
      "id": "fallback_title",
      "label": "t:sections.product_showcase.label_titel_fallback",
      "info": "t:sections.product_showcase.info_wird_gezeigt_wenn_kein_produkt_ausgewaeh"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "t:sections.product_showcase.label_beschreibung_ueberschreibt_produkt_besch"
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "t:sections.product_showcase.label_marke_anzeigen",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_buy_now",
      "label": "t:sections.product_showcase.label_sofort_kaufen_button",
      "default": false
    },
    {
      "type": "header",
      "content": "t:sections.product_showcase.content_video_autoplay_1_hover_replay"
    },
    {
      "type": "paragraph",
      "content": "t:sections.product_showcase.content_video_wird_beim_laden_einmal_stumm_abges"
    },
    {
      "type": "video",
      "id": "video",
      "label": "t:sections.product_showcase.label_video_shopify_upload"
    },
    {
      "type": "video_url",
      "id": "video_url",
      "label": "t:sections.product_showcase.label_alternativ_youtube_vimeo_url",
      "accept": [
        "youtube",
        "vimeo"
      ]
    },
    {
      "type": "image_picker",
      "id": "last_frame",
      "label": "t:sections.product_showcase.label_standbild_letztes_frame",
      "info": "t:sections.product_showcase.info_optional_wird_nach_ende_des_videos_angez"
    },
    {
      "type": "checkbox",
      "id": "autoplay_once",
      "label": "t:sections.product_showcase.label_beim_laden_einmal_automatisch_abspielen",
      "default": true
    },
    {
      "type": "header",
      "content": "t:sections.product_showcase.content_3d_modell"
    },
    {
      "type": "paragraph",
      "content": "t:sections.product_showcase.content_3d_modell_fuer_die_interaktive_ansicht_a"
    },
    {
      "type": "header",
      "content": "t:sections.product_showcase.content_meta_usps"
    },
    {
      "type": "checkbox",
      "id": "show_meta",
      "label": "t:sections.product_showcase.label_meta_zeile_anzeigen",
      "default": true
    },
    {
      "type": "text",
      "id": "meta_1",
      "label": "t:sections.product_showcase.label_meta_1",
      "default": "t:sections.product_showcase.default_kostenloser_versand_ab_80"
    },
    {
      "type": "text",
      "id": "meta_2",
      "label": "t:sections.product_showcase.label_meta_2",
      "default": "t:sections.product_showcase.default_30_tage_rueckgaberecht"
    },
    {
      "type": "text",
      "id": "meta_3",
      "label": "t:sections.product_showcase.label_meta_3",
      "default": "t:sections.product_showcase.default_nachhaltig_produziert"
    },
    {
      "type": "header",
      "content": "t:sections.product_showcase.content_layout_farben"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "t:sections.product_showcase.label_hintergrund",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "t:sections.product_showcase.label_text",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "t:sections.product_showcase.label_akzent_buttons",
      "default": "#111111"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "t:sections.product_showcase.label_abstand_oben",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "t:sections.product_showcase.label_abstand_unten",
      "default": 64
    }
  ],
  "blocks": [
    {
      "type": "accordion",
      "name": "t:sections.product_showcase_blocks.name_akkordeon",
      "limit": 6,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "t:sections.product_showcase.label_ueberschrift",
          "default": "t:sections.product_showcase.default_details"
        },
        {
          "type": "richtext",
          "id": "content",
          "label": "t:sections.product_showcase.label_inhalt",
          "default": "t:sections.product_showcase.default_p_material_100_bio_baumwolle_made_in_por"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.product_showcase.preset_produkt_showcase",
      "blocks": [
        {
          "type": "accordion",
          "settings": {
            "heading": "Details & Material"
          }
        },
        {
          "type": "accordion",
          "settings": {
            "heading": "Pflegehinweise"
          }
        },
        {
          "type": "accordion",
          "settings": {
            "heading": "Versand & Rückgabe"
          }
        }
      ],
      "settings": {
        "color_scheme": "scheme-1"
      }
    }
  ],
  "disabled_on": {
    "groups": [
      "header",
      "footer"
    ]
  }
}
{% endschema %}
