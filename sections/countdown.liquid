{%- comment -%}
  Countdown / Drop Timer — for upcoming collection launches, sales, or limited drops.
  Uses a Custom Element for the countdown logic. No external dependencies.
  Supports background image, overlay, and custom text.
{%- endcomment -%}

{{ 'section-countdown.css' | asset_url | stylesheet_tag }}

{%- assign scheme = section.settings.color_scheme -%}
<section
  class="countdown full-width color-scheme color-{{ scheme.id }}"
  data-section-id="{{ section.id }}"
>
  {% style %}
    {%- if scheme -%}
    .color-{{ scheme.id }} {
      --color-background: {{ scheme.settings.background.red }}, {{ scheme.settings.background.green }}, {{ scheme.settings.background.blue }};
      --color-text: {{ scheme.settings.text.red }}, {{ scheme.settings.text.green }}, {{ scheme.settings.text.blue }};
      --color-button: {{ scheme.settings.button.red }}, {{ scheme.settings.button.green }}, {{ scheme.settings.button.blue }};
      --color-button-label: {{ scheme.settings.button_label.red }}, {{ scheme.settings.button_label.green }}, {{ scheme.settings.button_label.blue }};
      color: rgb(var(--color-text));
      background-color: rgb(var(--color-background));
      {%- if scheme.settings.background_gradient != blank -%}
      background: {{ scheme.settings.background_gradient }};
      {%- endif -%}
    }
    {%- endif -%}
    #shopify-section-{{ section.id }} {
      --section-padding-top: {{ section.settings.padding_top }}px;
      --section-padding-bottom: {{ section.settings.padding_bottom }}px;
      --countdown-text-color: {{ section.settings.text_color }};
    }
  {% endstyle %}

  <div class="countdown__wrapper">
    {%- if section.settings.image != blank -%}
      <div class="countdown__bg">
        {%- assign cd_alt = section.settings.heading | default: shop.name | escape -%}
        {{ section.settings.image | image_url: width: 1800 | image_tag:
          loading: 'lazy',
          sizes: '100vw',
          widths: '600,900,1200,1600,1800',
          alt: cd_alt,
          class: 'countdown__bg-image'
        }}
        <div class="countdown__overlay" style="opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};"></div>
      </div>
    {%- endif -%}

    <div class="countdown__content">
      {%- if section.settings.eyebrow != blank -%}
        <p class="countdown__eyebrow">{{ section.settings.eyebrow | escape }}</p>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h2 class="countdown__heading">{{ section.settings.heading | escape }}</h2>
      {%- endif -%}

      {%- if section.settings.text != blank -%}
        <div class="countdown__text">{{ section.settings.text }}</div>
      {%- endif -%}

      <countdown-timer
        class="countdown__timer"
        data-target="{{ section.settings.target_date }}"
        data-expired-text="{{ 'sections.countdown.expired' | t | escape }}"
      >
        <div class="countdown__digits" aria-live="polite" aria-atomic="true">
          <div class="countdown__unit">
            <span class="countdown__number" data-days>00</span>
            <span class="countdown__label">{{ 'sections.countdown.days' | t }}</span>
          </div>
          <span class="countdown__sep" aria-hidden="true">:</span>
          <div class="countdown__unit">
            <span class="countdown__number" data-hours>00</span>
            <span class="countdown__label">{{ 'sections.countdown.hours' | t }}</span>
          </div>
          <span class="countdown__sep" aria-hidden="true">:</span>
          <div class="countdown__unit">
            <span class="countdown__number" data-minutes>00</span>
            <span class="countdown__label">{{ 'sections.countdown.minutes' | t }}</span>
          </div>
          <span class="countdown__sep" aria-hidden="true">:</span>
          <div class="countdown__unit">
            <span class="countdown__number" data-seconds>00</span>
            <span class="countdown__label">{{ 'sections.countdown.seconds' | t }}</span>
          </div>
        </div>
      </countdown-timer>

      {%- if section.settings.button_label != blank and section.settings.button_link != blank -%}
        <a href="{{ section.settings.button_link }}" class="countdown__btn">
          {{ section.settings.button_label | escape }}
        </a>
      {%- endif -%}
    </div>
  </div>
</section>

<script src="{{ 'countdown-timer.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "t:sections.countdown.name",
  "tag": "section",
  "class": "section-countdown",
  "limit": 2,
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:labels.color_scheme",
      "default": "scheme-2"
    },
    {
      "type": "text",
      "id": "target_date",
      "label": "t:sections.countdown.target_date",
      "info": "t:sections.countdown.target_date_info",
      "default": "2026-06-01T00:00:00"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "t:labels.subheading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.heading",
      "default": "t:sections.countdown.heading_default"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "t:labels.text"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "t:labels.button_text",
      "default": "t:sections.countdown.btn_default"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "t:labels.button_link"
    },
    {
      "type": "header",
      "content": "t:sections.countdown.background_header"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:labels.image"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "%",
      "label": "t:sections.countdown.overlay",
      "default": 40
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "t:labels.text",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:labels.padding_top",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:labels.padding_bottom",
      "default": 64
    }
  ],
  "presets": [
    {
      "name": "t:sections.countdown.preset_name",
      "settings": {
        "heading": "t:sections.countdown.heading_default",
        "eyebrow": "Coming soon",
        "color_scheme": "scheme-2"
      }
    }
  ],
  "disabled_on": {
    "groups": ["header", "footer"]
  }
}
{% endschema %}
