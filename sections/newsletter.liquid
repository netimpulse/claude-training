<section class="nl color-scheme color-{{ section.settings.color_scheme.id }}" data-section-id="{{ section.id }}">
  <div class="nl__inner">
    {%- if section.settings.eyebrow != blank -%}<p class="nl__eyebrow">{{ section.settings.eyebrow | escape }}</p>{%- endif -%}
    <h2 class="nl__heading">{{ section.settings.heading | escape | default: 'Newsletter' }}</h2>
    {%- if section.settings.text != blank -%}<div class="nl__text">{{ section.settings.text }}</div>{%- endif -%}
    {%- form 'customer', class: 'nl__form' -%}
      <input type="hidden" name="contact[tags]" value="newsletter">
      <label for="Newsletter-{{ section.id }}" class="visually-hidden">E-Mail-Adresse</label>
      <div class="nl__input-wrap">
        <input id="Newsletter-{{ section.id }}" type="email" name="contact[email]"
               placeholder="{{ section.settings.placeholder | default: 'E-Mail-Adresse' | escape }}"
               autocomplete="email" required>
        <button type="submit">{{ section.settings.button_label | default: 'Anmelden' | escape }}</button>
      </div>
      {%- if form.posted_successfully? -%}<p class="nl__success" role="status">Danke – bitte bestätige deine E-Mail.</p>{%- endif -%}
      {%- if form.errors -%}<p class="nl__error" role="alert">{{ form.errors | default_errors }}</p>{%- endif -%}
    {%- endform -%}
  </div>
</section>
{% style %}
  {%- assign scheme = section.settings.color_scheme -%}
  {%- if scheme -%}
  .color-{{ scheme.id }} {
    --color-background: {{ scheme.settings.background.red }}, {{ scheme.settings.background.green }}, {{ scheme.settings.background.blue }};
    --color-text: {{ scheme.settings.text.red }}, {{ scheme.settings.text.green }}, {{ scheme.settings.text.blue }};
    --color-button: {{ scheme.settings.button.red }}, {{ scheme.settings.button.green }}, {{ scheme.settings.button.blue }};
    --color-button-label: {{ scheme.settings.button_label.red }}, {{ scheme.settings.button_label.green }}, {{ scheme.settings.button_label.blue }};
    --color-secondary-button-label: {{ scheme.settings.secondary_button_label.red }}, {{ scheme.settings.secondary_button_label.green }}, {{ scheme.settings.secondary_button_label.blue }};
    --color-shadow: {{ scheme.settings.shadow.red }}, {{ scheme.settings.shadow.green }}, {{ scheme.settings.shadow.blue }};
    color: rgb(var(--color-text));
    background-color: rgb(var(--color-background));
    {%- if scheme.settings.background_gradient != blank -%}
    background: {{ scheme.settings.background_gradient }};
    {%- endif -%}
  }
  {%- endif -%}

  #shopify-section-{{ section.id }} {
    --nl-bg: {{ section.settings.bg_color }};
    --nl-fg: {{ section.settings.text_color }};
    --nl-padding-top: {{ section.settings.padding_top }}px;
    --nl-padding-bottom: {{ section.settings.padding_bottom }}px;
  }
{% endstyle %}
{{ 'section-newsletter.css' | asset_url | stylesheet_tag }}
{% schema %}
{
  "name": "t:sections.newsletter.name_newsletter",
  "tag": "section",
  "class": "section-newsletter",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.newsletter.label_farbschema",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "t:sections.newsletter.label_eyebrow",
      "default": "t:sections.newsletter.default_bleib_im_loop"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.newsletter.label_ueberschrift",
      "default": "t:sections.newsletter.default_10_auf_deine_erste_bestellung"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "t:sections.newsletter.label_text",
      "default": "t:sections.newsletter.default_p_neue_drops_exklusive_previews_und_styl"
    },
    {
      "type": "text",
      "id": "placeholder",
      "label": "t:sections.newsletter.label_placeholder",
      "default": "t:sections.newsletter.default_e_mail_adresse"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "t:sections.newsletter.label_button_text",
      "default": "t:sections.newsletter.default_anmelden"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "t:sections.newsletter.label_hintergrund",
      "default": "#f6f5f2"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "t:sections.newsletter.label_text",
      "default": "#111111"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "t:sections.newsletter.label_abstand_oben",
      "default": 72
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "t:sections.newsletter.label_abstand_unten",
      "default": 72
    }
  ],
  "presets": [
    {
      "name": "t:sections.newsletter.preset_newsletter",
      "settings": {
        "color_scheme": "scheme-1"
      }
    }
  ],
  "disabled_on": {
    "groups": [
      "header",
      "footer"
    ]
  }
}
{% endschema %}
