{%- comment -%}
  Renders main menu in header (desktop).

  @param {linklist} menu - Menu object from section settings
{%- endcomment -%}
{%- if menu != blank and menu.links.size > 0 -%}
  <ul class="site-main-menu__list" role="list">
    {%- for link in menu.links -%}
      <li class="site-main-menu__item {% if link.active or link.child_active %}is-active{% endif %}">
        <a href="{{ link.url }}" class="site-main-menu__link" {% if link.current %}aria-current="page"{% endif %}>
          {{ link.title | escape }}
        </a>
        {%- if link.links.size > 0 -%}
          <div class="site-main-menu__submenu">
            <ul class="site-main-menu__sublist" role="list">
              {%- for sub in link.links -%}
                <li>
                  <a href="{{ sub.url }}" class="site-main-menu__sublink" {% if sub.current %}aria-current="page"{% endif %}>
                    {{ sub.title | escape }}
                  </a>
                </li>
              {%- endfor -%}
            </ul>
          </div>
        {%- endif -%}
      </li>
    {%- endfor -%}
  </ul>
{%- endif -%}
