{%- comment -%}
  Renders the shop logo as image or text link.
  Accepts: settings (section.settings)
{%- endcomment -%}
{%- assign logo_alt = shop.name | escape -%}
{%- assign logo_w = settings.logo_width | default: 120 -%}
{%- assign logo_w_2x = logo_w | times: 2 -%}
{%- assign logo_style = 'width:' | append: logo_w | append: 'px;' -%}
<a href="{{ routes.root_url }}" class="site-logo" aria-label="{{ shop.name | escape }}">
  {%- if settings.logo != blank -%}
    {{ settings.logo | image_url: width: logo_w_2x | image_tag:
        loading: 'eager',
        fetchpriority: 'high',
        sizes: '(min-width: 768px) 200px, 120px',
        widths: '120,200,280,400,560',
        alt: logo_alt,
        style: logo_style,
        class: 'site-logo__image'
    }}
  {%- else -%}
    <s