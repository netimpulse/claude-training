[
  {
    "name": "theme_info",
    "theme_name": "Skeleton Fashion",
    "theme_version": "1.0.0",
    "theme_author": "netimpulse",
    "theme_documentation_url": "https://netimpulse.de/themes/skeleton-fashion/docs",
    "theme_support_url": "https://netimpulse.de/themes/skeleton-fashion/support"
  },
  {
    "name": "t:general.typography",
    "settings": [
      { "type": "header", "content": "t:general.fonts" },
      {
        "type": "font_picker",
        "id": "type_primary_font",
        "default": "work_sans_n4",
        "label": "t:general.primary"
      },
      {
        "type": "font_picker",
        "id": "type_heading_font",
        "default": "work_sans_n7",
        "label": "t:settings.heading_font"
      }
    ]
  },
  {
    "name": "t:general.layout",
    "settings": [
      {
        "type": "select",
        "id": "max_page_width",
        "label": "t:labels.page_width",
        "options": [
          { "value": "90rem", "label": "t:options.page_width.narrow" },
          { "value": "110rem", "label": "t:options.page_width.wide" }
        ],
        "default": "90rem"
      },
      {
        "type": "range",
        "id": "min_page_margin",
        "min": 10,
        "max": 100,
        "step": 1,
        "unit": "px",
        "label": "t:labels.page_margin",
        "default": 20
      },
      {
        "type": "range",
        "id": "input_corner_radius",
        "min": 0,
        "max": 10,
        "step": 1,
        "unit": "px",
        "label": "t:labels.input_corner_radius",
        "default": 4
      }
    ]
  },
  {
    "name": "t:settings.favicon",
    "settings": [
      {
        "type": "image_picker",
        "id": "favicon",
        "label": "t:settings.favicon_image",
        "info": "t:settings.favicon_info"
      }
    ]
  },
  {
    "name": "t:settings.social_media",
    "settings": [
      {
        "type": "text",
        "id": "social_facebook_link",
        "label": "t:settings.social_facebook",
        "info": "https://facebook.com/shopname"
      },
      {
        "type": "text",
        "id": "social_instagram_link",
        "label": "t:settings.social_instagram",
        "info": "https://instagram.com/shopname"
      },
      {
        "type": "text",
        "id": "social_tiktok_link",
        "label": "t:settings.social_tiktok",
        "info": "https://tiktok.com/@shopname"
      },
      {
        "type": "text",
        "id": "social_youtube_link",
        "label": "t:settings.social_youtube",
        "info": "https://youtube.com/shopname"
      },
      {
        "type": "text",
        "id": "social_pinterest_link",
        "label": "t:settings.social_pinterest",
        "info": "https://pinterest.com/shopname"
      },
      {
        "type": "text",
        "id": "social_twitter_link",
        "label": "t:settings.social_twitter",
        "info": "https://x.com/shopname"
      }
    ]
  },
  {
    "name": "t:general.color_schemes",
    "settings": [
      {
        "type": "color_scheme_group",
        "id": "color_schemes",
        "definition": [
          {
            "type": "color",
            "id": "background",
            "label": "t:labels.background",
            "default": "#FFFFFF"
          },
          {
            "type": "color_background",
            "id": "background_gradient",
            "label": "t:labels.background_gradient"
          },
          {
            "type": "color",
            "id": "text",
            "label": "t:labels.text",
            "default": "#121212"
          },
          {
            "type": "color",
            "id": "button",
            "label": "t:labels.button_background",
            "default": "#121212"
          },
          {
            "type": "color",
            "id": "button_label",
            "label": "t:labels.button_label",
            "default": "#FFFFFF"
          },
          {
            "type": "color",
            "id": "secondary_button_label",
            "label": "t:labels.outline_button_label",
            "default": "#121212"
          },
          {
            "type": "color",
            "id": "shadow",
            "label": "t:labels.shadow",
            "default": "#121212"
          }
        ],
        "role": {
          "text": "text",
          "background": {
            "solid": "background",
            "gradient": "background_gradient"
          },
          "links": "secondary_button_label",
          "icons": "text",
          "primary_button": "button",
          "on_primary_button": "button_label",
          "primary_button_border": "button",
          "secondary_button": "background",
          "on_secondary_button": "secondary_button_label",
          "secondary_button_border": "secondary_button_label"
        }
      }
    ]
  }
]
